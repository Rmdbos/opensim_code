<ForwardTool name="ToyLandingModel"> 
 
   
  <model_file>ToyLandingModel_scaled.osim</model_file> 
  
	<replace_force_set>false</replace_force_set>
 
   
  <initial_time> 0.00 </initial_time> 
  
	<final_time>0.40000000000000002</final_time>
  
